# Smolfile — declarative per-issue microVM for smol-symphony.
#
# Used by smolvm when symphony's runner does `machine create -s Smolfile` (driven by
# the `smolvm.smolfile` workflow key in WORKFLOW.md). Single source of truth for the
# image, resource budget, and in-VM setup.
#
# [dev].init runs on every machine start, so a fresh per-issue VM pays the apt + npm
# install on each dispatch. For a single-developer setup that's fine; to amortise the
# cost, pre-build a custom OCI image with these layers baked in and switch `image`
# below to point at it (or run `smolvm pack create --from-vm <name> -o symphony.smolmachine`
# once and set `smolvm.from` in WORKFLOW.md instead of `smolvm.smolfile`).

image = "node:24-bookworm-slim"

cpus = 2
memory = 4096
net = true

[dev]
# scripts/ is BAKED INTO the image (it used to be a runtime bind-mount at
# /opt/symphony). It is mounted read-only at a scratch path *during bake only*;
# the init `cp` below copies it into the real /opt/symphony in the rootfs, so the
# packed artifact carries vm-agent.mjs and a `--from` dispatch needs NO
# /opt/symphony mount. That frees one of smolvm/libkrun's 3 virtio-fs slots for
# the eval_mode read-only mounts (/symphony/issues + /symphony/logs) — a 4th
# mount makes `krun_start_enter` return -22 (the sleep-cycle bring-up failure).
# The runtime mount was removed from `smolvm.volumes` in WORKFLOW.md.
#
# Correctness: the reconciler's bake hash folds in the content of the host dirs
# this Smolfile mounts (scripts/), so editing vm-agent.mjs invalidates the cached
# artifact and forces a re-bake — no stale copy can persist. Path is resolved
# relative to this Smolfile.
volumes = ["./scripts:/opt/symphony-src:ro"]

# Install base CLI tooling + every ACP-capable coding agent symphony's adapter
# registry knows how to launch (claude-agent-acp, codex-acp, opencode). The
# `--no-install-recommends` keeps the apt layer slim; `--no-audit --no-fund`
# strips npm output the orchestrator would otherwise log per dispatch.
#
# codex (@openai/codex + @zed-industries/codex-acp) is PINNED: an unpinned
# global install means a rebake can silently change codex's Responses-API
# transport behavior, which is exactly what broke codex review against the
# credential proxy in issue #127 (the WebSocket Responses transport bypassed the
# proxy and leaked the per-dispatch sentinel to OpenAI). Bump these deliberately.
#
# opencode (opencode-ai) is PINNED for the same reason (issue #130): the opencode
# proxy adapter depends on opencode's `opencode acp` config-merge + custom-provider
# + `{env:VAR}` interpolation + model-selection behavior, all of which an unpinned
# rebake could silently change. Bump deliberately and re-verify against
# docs/research/opencode-copilot-accept-matrix.md.
init = [
    # Bake the host scripts/ (mounted read-only at the scratch path above) into
    # the rootfs at /opt/symphony so the runtime needs no bind-mount. cp -a keeps
    # vm-agent.mjs executable.
    "mkdir -p /opt/symphony",
    "cp -a /opt/symphony-src/. /opt/symphony/",
    "apt-get update -q",
    "apt-get install -y --no-install-recommends git ripgrep ca-certificates curl",
    "npm install -g --no-audit --no-fund @openai/codex@0.135.0 @anthropic-ai/claude-code @agentclientprotocol/claude-agent-acp @zed-industries/codex-acp@0.15.0 opencode-ai@1.15.12",
]
